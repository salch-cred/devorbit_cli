# Get a free key at https://build.nvidia.com (click any model -> Get API Key)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional providers (select with: /settings set models.provider openai)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
OLLAMA_API_KEY=ollama
LMSTUDIO_API_KEY=lm-studio

# --- GitHub connection (optional, needed for GitHub tools) ---
# Create a fine-grained personal access token at https://github.com/settings/tokens
# Needs Contents, Issues, and Pull requests read/write on the repos you want to use.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default repo used when a tool call doesn't specify one, format: owner/repo
GITHUB_REPO=your-username/your-repo

# --- File tools ---
# All file read/write/edit tools are sandboxed to this local folder.
WORKSPACE_DIR=./workspace

# When true, the CLI executes file/git/GitHub write actions without asking y/N first.
# Leave false unless you fully trust the model + prompts you're using.
AUTO_APPROVE=false
